# Installed app: ~/Library/Application Support/TrustEdgeClient/.env
# Running from source: copy to .env in the repo root (see docs/BUILD.md)
# Never commit .env — it may contain secrets.

# TrustEdge API base URL (required for API enrollment mode)
TRUSTEDGE_API_URL=https://your-api.example.com

# Optional: Bearer token for POST /v1/enroll
TRUSTEDGE_API_TOKEN=
